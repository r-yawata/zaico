model Supplier {
  id         Int       @id @default(autoincrement())
  name       String    @map("name")
  contact    String?   @map("contact")
  address    String?   @map("address")
  createdAt  DateTime  @default(now()) @map("created_at") 
  updatedAt  DateTime  @updatedAt @map("updated_at")

  materials  Material[]
} 